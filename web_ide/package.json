{
	"name": "simflow",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "npm run build-web -- --sourcemap=inline --watch",
		"build-widget": "esbuild js/widget.tsx --minify --format=esm --bundle --outdir=src/simflow/static",
		"build-web": "esbuild --platform=browser --bundle js/index.tsx --format=esm --sourcemap --loader:.png=file --loader:.css=css js/widget.css --loader:.html=copy js/index.html --outdir=web",
		"lint": "eslint ."
	},
	"dependencies": {
		"@anywidget/react": "^0.2.0",
		"@dagrejs/dagre": "^1.1.8",
		"@tailwindcss/vite": "^4.1.18",
		"@xyflow/react": "^12.10.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.563.0",
		"pyodide": "^0.29.3",
		"radix-ui": "^1.4.3",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"vite": "^7.3.1",
		"vite-react": "^5.0.0"
	},
	"devDependencies": {
		"@types/react": "^19.1.3",
		"@types/react-dom": "^19.1.4",
		"esbuild": "^0.25.4",
		"eslint": "^9.39.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.4.26",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.54.0"
	}
}
